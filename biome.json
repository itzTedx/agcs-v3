{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"],
    "ignoreUnknown": false
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noConstantCondition": "warn"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "useSortedAttributes": "on",
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":TYPES:",
              ["react", "react/**"],
              ":BLANK_LINE:",
              ["next", "next/**"],
              ":BLANK_LINE:",

              [":PACKAGE:", "!@ziron", "!@ziron/**"],
              ":BLANK_LINE:",

              ["@ziron", "@ziron/**"],
              ":BLANK_LINE:",

              ["@", "@/components/**"],
              ":BLANK_LINE:",

              ["@", "@/assets/**"],
              ":BLANK_LINE:",

              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  }
}
